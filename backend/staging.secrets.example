# Staging secrets — gitignored copy: backend/staging.secrets
# Replace every placeholder before deploying; never commit real staging credentials.

POSTGRES_PASSWORD=REPLACE_STAGING_POSTGRES_PASSWORD
STATISTICS_PG_URL=postgres://STAGING_USER:REPLACE_STAGING_POSTGRES_PASSWORD@staging-postgres.example.net:5432/triage_stats
MONGO_URI=mongodb+srv://STAGING_USER:REPLACE_STAGING_MONGO_PASSWORD@staging-mongo.example.net/triage_staging

JWT_SECRET=REPLACE_STAGING_JWT_SECRET
DJANGO_SECRET_KEY=REPLACE_STAGING_DJANGO_SECRET
NEO4J_PASSWORD=REPLACE_STAGING_NEO4J_PASSWORD
GRAPH_INTERNAL_TOKEN=REPLACE_STAGING_GRAPH_INTERNAL_TOKEN

CELERY_BROKER_URL=rediss://:REPLACE_STAGING_REDIS_PASS@staging-redis.example.net:6380/0
CELERY_RESULT_BACKEND=rediss://:REPLACE_STAGING_REDIS_PASS@staging-redis.example.net:6380/1

LLM_API_KEY=REPLACE_STAGING_LLM_KEY
GOOGLE_OAUTH_CLIENT_SECRET=REPLACE_STAGING_OAUTH_SECRET
