# Dev secrets — gitignored copy: backend/dev.secrets (create from this example).
# Loaded at container startup via mock AWS Secrets Manager (secret id triage/dev).
# Never commit real production values; CI uses ci.secrets with fake credentials only.

# PostgreSQL (must match infra/docker postgres service password for local dev).
POSTGRES_PASSWORD=triage
STATISTICS_PG_URL=postgres://triage:triage@postgres:5432/triage_stats

# JWT signing key for login tokens (rotate per ops_guide_secrets_management.md).
JWT_SECRET=dev-jwt-secret-change-before-staging-or-prod

# Django admin compatibility secret (separate from JWT).
DJANGO_SECRET_KEY=dev-secret

# Neo4j graph database (must match NEO4J_AUTH in docker-compose for dev).
NEO4J_PASSWORD=triage-neo4j-dev

# Internal token for Celery → Node graph sync callback (not a JWT).
GRAPH_INTERNAL_TOKEN=dev-graph-sync-token

# Mock commercial LLM API key (mock-llm container accepts any dev key).
LLM_API_KEY=dev-mock-key

# Bootstrap admin password for first login (email goes in dev.secrets too after configure script).
AUTH_BOOTSTRAP_ADMIN_PASSWORD=temp-admin-pswd

# Optional OAuth / SMTP overrides — uncomment and fill after Google or SMTP setup scripts.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REFRESH_TOKEN=
# SMTP_USER=
# SMTP_PASS=
