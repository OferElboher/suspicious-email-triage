# Copy one profile file when you need a private override:
#   cp backend/.env.dev backend/.env
#
# Runtime default:
# - backend/src/config/runtime.js loads backend/.env.dev unless DEPLOYMENT_ENV/APP_ENV/ENV_FILE says otherwise.
# - backend/.env.staging and backend/.env.prod contain sample remote values only.

DEPLOYMENT_ENV=dev
APP_ENV=dev
NODE_ENV=development
PORT=3000

# MongoDB stores review requests and analysis results.
MONGO_URI=mongodb://mongo:27017/triage

# PostgreSQL stores compact chart/statistics events.
STATISTICS_PG_URL=postgres://triage:triage@postgres:5432/triage_stats

# Redis, Celery, and Kafka/Redpanda.
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
KAFKA_BROKERS=redpanda:9092
KAFKA_TOPIC_REVIEW_INGEST=email.review.ingested

# Pipeline toggles.
USE_KAFKA_INGEST=true
USE_BULLMQ_ENQUEUE=false
DISABLE_LLM=true
