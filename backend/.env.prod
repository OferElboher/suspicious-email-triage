# Production profile: non-sensitive metadata only — credentials in AWS Secrets Manager (triage/prod).
DEPLOYMENT_ENV=prod
APP_ENV=prod
NODE_ENV=production
PORT=3000

SECRETS_PROVIDER=aws
SECRETS_MANAGER_URL=https://secretsmanager.us-east-1.amazonaws.com
SECRETS_BUNDLE_ID=triage/prod
AWS_REGION=us-east-1

POSTGRES_DB=triage_stats
POSTGRES_USER=PROD_USER
POSTGRES_HOST=prod-postgres.example.net
POSTGRES_PORT=5432

REDIS_HOST=prod-redis.example.net
REDIS_PORT=6380

KAFKA_BROKERS=prod-kafka.example.net:9092
KAFKA_BOOTSTRAP_SERVERS=prod-kafka.example.net:9092
KAFKA_TOPIC_REVIEW_INGEST=email.review.ingested

USE_KAFKA_INGEST=true
USE_BULLMQ_ENQUEUE=false

MERGED_LOG_PATH=/var/log/triage/merged.log
SIMULATION_MAX_EVENTS_PER_MIN=0

# Real commercial LLM at scale — OpenAI/Azure OpenAI/Anthropic via OpenAI-compatible URL.
DISABLE_LLM=false
LLM_PROVIDER=mock_commercial
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=512
LLM_SYSTEM_PROMPT=You are a cybersecurity email analyst. Return strict JSON only.

ENVIRONMENT=prod
ALLOWED_HOSTS=triage.example.com
APP_PUBLIC_URL=https://triage.example.com

EMAIL_DELIVERY=external
SMTP_DELIVERY=external
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_FROM=noreply@triage.example.com

NEO4J_ENABLED=true
NEO4J_URI=bolt://prod-neo4j.example.net:7687
NEO4J_USER=neo4j
BACKEND_INTERNAL_URL=http://backend:3000

ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_URL=https://prod-elasticsearch.example.net:9200
ELASTICSEARCH_REVIEWS_INDEX=triage-reviews

SNOWFLAKE_ENABLED=true
SNOWFLAKE_URL=https://prod-account.snowflakecomputing.com

# Amazon S3 backups — production bucket with lifecycle policy (see ops_guide_s3_backups.md).
BACKUP_PROVIDER=aws
BACKUP_S3_BUCKET=triage-prod-backups
AWS_REGION=us-east-1
