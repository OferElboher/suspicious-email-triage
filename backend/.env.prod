# Production profile: sample remote values only; real values belong in secrets.
DEPLOYMENT_ENV=prod
APP_ENV=prod
NODE_ENV=production
PORT=3000

# Remote MongoDB stores review requests and analysis results.
MONGO_URI=mongodb+srv://PROD_USER:PROD_PASS@prod-mongo.example.net/triage

# Remote PostgreSQL stores chart/statistics events.
POSTGRES_DB=triage_stats
POSTGRES_USER=PROD_USER
POSTGRES_PASSWORD=PROD_PASS
POSTGRES_HOST=prod-postgres.example.net
POSTGRES_PORT=5432
STATISTICS_PG_URL=postgres://PROD_USER:PROD_PASS@prod-postgres.example.net:5432/triage_stats

# Remote Redis/Celery endpoints.
REDIS_HOST=prod-redis.example.net
REDIS_PORT=6380
CELERY_BROKER_URL=rediss://:PROD_REDIS_PASS@prod-redis.example.net:6380/0
CELERY_RESULT_BACKEND=rediss://:PROD_REDIS_PASS@prod-redis.example.net:6380/1

# Remote Kafka-compatible broker.
KAFKA_BROKERS=prod-kafka.example.net:9092
KAFKA_BOOTSTRAP_SERVERS=prod-kafka.example.net:9092
KAFKA_TOPIC_REVIEW_INGEST=email.review.ingested

# Production uses the Kafka/Celery path and keeps legacy fallback off.
USE_KAFKA_INGEST=true
USE_BULLMQ_ENQUEUE=false

# Production logs should usually be shipped by the platform.
MERGED_LOG_PATH=/var/log/triage/merged.log
SIMULATION_MAX_EVENTS_PER_MIN=0

# Sample model settings; replace with production-specific values if enabled.
DISABLE_LLM=true
OLLAMA_URL=http://prod-ollama.example.net:11434/api/generate
OLLAMA_MODEL=llama3

# Django-side compatibility settings.
ENVIRONMENT=prod
DJANGO_SECRET_KEY=replace-with-production-secret
ALLOWED_HOSTS=triage.example.com
