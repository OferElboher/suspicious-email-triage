# Staging profile: sample remote values only; replace through CI/secrets.
DEPLOYMENT_ENV=staging
APP_ENV=staging
NODE_ENV=production
PORT=3000

# Remote MongoDB stores review requests and analysis results.
MONGO_URI=mongodb+srv://STAGING_USER:STAGING_PASS@staging-mongo.example.net/triage_staging

# Remote PostgreSQL stores chart/statistics events.
POSTGRES_DB=triage_stats
POSTGRES_USER=STAGING_USER
POSTGRES_PASSWORD=STAGING_PASS
POSTGRES_HOST=staging-postgres.example.net
POSTGRES_PORT=5432
STATISTICS_PG_URL=postgres://STAGING_USER:STAGING_PASS@staging-postgres.example.net:5432/triage_stats

# Remote Redis/Celery endpoints.
REDIS_HOST=staging-redis.example.net
REDIS_PORT=6380
CELERY_BROKER_URL=rediss://:STAGING_REDIS_PASS@staging-redis.example.net:6380/0
CELERY_RESULT_BACKEND=rediss://:STAGING_REDIS_PASS@staging-redis.example.net:6380/1

# Remote Kafka-compatible broker.
KAFKA_BROKERS=staging-kafka.example.net:9092
KAFKA_BOOTSTRAP_SERVERS=staging-kafka.example.net:9092
KAFKA_TOPIC_REVIEW_INGEST=email.review.ingested

# Staging uses the Kafka/Celery path and disables dev-only fallback.
USE_KAFKA_INGEST=true
USE_BULLMQ_ENQUEUE=false

# Staging logs should usually be shipped by the platform.
MERGED_LOG_PATH=/var/log/triage/merged.log
SIMULATION_MAX_EVENTS_PER_MIN=0

# Sample model settings; replace with staging-specific values if enabled.
DISABLE_LLM=true
OLLAMA_URL=http://staging-ollama.example.net:11434/api/generate
OLLAMA_MODEL=llama3

# Django-side compatibility settings.
ENVIRONMENT=staging
DJANGO_SECRET_KEY=replace-with-staging-secret
ALLOWED_HOSTS=staging.example.net,localhost
