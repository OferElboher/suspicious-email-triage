# Staging profile: non-sensitive metadata only — credentials in AWS Secrets Manager (triage/staging).
# Pattern: same application code as dev; URLs point at managed cloud services instead of Docker mocks.
DEPLOYMENT_ENV=staging
APP_ENV=staging
NODE_ENV=production
PORT=3000

# Real AWS Secrets Manager (IAM role on EKS/ECS, or keys from CI deploy role).
SECRETS_PROVIDER=aws
SECRETS_MANAGER_URL=https://secretsmanager.us-east-1.amazonaws.com
SECRETS_BUNDLE_ID=triage/staging
AWS_REGION=us-east-1

# Remote service hostnames (passwords and URIs with credentials live in staging.secrets / AWS bundle).
POSTGRES_DB=triage_stats
POSTGRES_USER=STAGING_USER
POSTGRES_HOST=staging-postgres.example.net
POSTGRES_PORT=5432

REDIS_HOST=staging-redis.example.net
REDIS_PORT=6380

KAFKA_BROKERS=staging-kafka.example.net:9092
KAFKA_BOOTSTRAP_SERVERS=staging-kafka.example.net:9092
KAFKA_TOPIC_REVIEW_INGEST=email.review.ingested

USE_KAFKA_INGEST=true
USE_BULLMQ_ENQUEUE=false

MERGED_LOG_PATH=/var/log/triage/merged.log
SIMULATION_MAX_EVENTS_PER_MIN=0

# Real commercial LLM — OpenAI-compatible API (not mock-llm). LLM_API_KEY in secrets bundle.
DISABLE_LLM=false
LLM_PROVIDER=mock_commercial
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=512
LLM_SYSTEM_PROMPT=You are a cybersecurity email analyst. Return strict JSON only.

ENVIRONMENT=staging
ALLOWED_HOSTS=staging.example.net,localhost
APP_PUBLIC_URL=https://staging.example.net

# Transactional email — Amazon SES or corporate SMTP (never Mailpit in staging).
EMAIL_DELIVERY=external
SMTP_DELIVERY=external
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_FROM=noreply@staging.example.net

NEO4J_ENABLED=true
NEO4J_URI=bolt://staging-neo4j.example.net:7687
NEO4J_USER=neo4j
BACKEND_INTERNAL_URL=http://backend:3000

ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_URL=https://staging-elasticsearch.example.net:9200
ELASTICSEARCH_REVIEWS_INDEX=triage-reviews-staging

# Real Snowflake account (HTTPS proxy or Snowflake SQL API gateway — not mock-snowflake).
SNOWFLAKE_ENABLED=true
SNOWFLAKE_URL=https://staging-account.snowflakecomputing.com
