# Production secrets — gitignored copy: backend/prod.secrets
# Inject via real AWS Secrets Manager in production; this file is for on-prem pilots only.

POSTGRES_PASSWORD=REPLACE_PROD_POSTGRES_PASSWORD
STATISTICS_PG_URL=postgres://PROD_USER:REPLACE_PROD_POSTGRES_PASSWORD@prod-postgres.example.net:5432/triage_stats
MONGO_URI=mongodb+srv://PROD_USER:REPLACE_PROD_MONGO_PASSWORD@prod-mongo.example.net/triage

JWT_SECRET=REPLACE_PROD_JWT_SECRET
DJANGO_SECRET_KEY=REPLACE_PROD_DJANGO_SECRET
NEO4J_PASSWORD=REPLACE_PROD_NEO4J_PASSWORD
GRAPH_INTERNAL_TOKEN=REPLACE_PROD_GRAPH_INTERNAL_TOKEN

CELERY_BROKER_URL=rediss://:REPLACE_PROD_REDIS_PASS@prod-redis.example.net:6380/0
CELERY_RESULT_BACKEND=rediss://:REPLACE_PROD_REDIS_PASS@prod-redis.example.net:6380/1

LLM_API_KEY=REPLACE_PROD_LLM_KEY
GOOGLE_OAUTH_CLIENT_SECRET=REPLACE_PROD_OAUTH_SECRET
