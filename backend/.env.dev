
# Dev profile: local Docker Compose services and safe defaults.
DEPLOYMENT_ENV=dev
APP_ENV=dev
NODE_ENV=development
PORT=3000

# MongoDB stores review requests and analysis results.
MONGO_URI=mongodb://mongo:27017/triage

# PostgreSQL stores compact chart/statistics events.
POSTGRES_DB=triage_stats
POSTGRES_USER=triage
POSTGRES_PASSWORD=triage
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
STATISTICS_PG_URL=postgres://triage:triage@postgres:5432/triage_stats

# Redis is used for Celery and optional BullMQ/dev state.
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Kafka/Redpanda carries review-ingest events.
KAFKA_BROKERS=redpanda:9092
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_TOPIC_REVIEW_INGEST=email.review.ingested
KAFKA_TOPIC_REVIEW_DLQ=email.review.ingested.dlq
KAFKA_TOPIC_PARTITIONS=3
KAFKA_AUTO_COMMIT=false
KAFKA_GROUP_DISPATCHER=triage-dispatcher

# Async path toggles.
USE_KAFKA_INGEST=true
USE_BULLMQ_ENQUEUE=false

# Local logs and simulation safety.
MERGED_LOG_PATH=/var/log/triage/merged.log
SIMULATION_MAX_EVENTS_PER_MIN=30

# LLM: disabled by default for deterministic CI; enable with DISABLE_LLM=false.
DISABLE_LLM=true
LLM_PROVIDER=mock_commercial
LLM_API_KEY=dev-mock-key
LLM_BASE_URL=http://mock-llm:8090/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=512
LLM_SYSTEM_PROMPT=You are a cybersecurity email analyst. Return strict JSON only.
OLLAMA_URL=http://host.docker.internal:11434/api/generate
OLLAMA_MODEL=llama3

# Django-side compatibility settings.
ENVIRONMENT=dev
DJANGO_SECRET_KEY=dev-secret
ALLOWED_HOSTS=localhost,127.0.0.1

# Authentication & RBAC (PostgreSQL-backed users in triage_stats).
JWT_SECRET=dev-jwt-secret-change-before-staging-or-prod
JWT_TTL_HOURS=12
# Bootstrap admin email: set in gitignored backend/.env — run:
#   bash scripts/configure-dev-bootstrap-admin.sh YOUR_EMAIL@example.com
AUTH_BOOTSTRAP_ADMIN_PASSWORD=temp-admin-pswd
AUTH_RESET_TOKEN_TTL_MINUTES=60
APP_PUBLIC_URL=http://localhost:3001
DJANGO_ADMIN_PUBLIC_URL=http://localhost:8000/admin/
# Password-reset email — Mailpit is the default (see docs/dev_smtp_password_recovery_email.md).
# gitignored backend/.env overrides these keys — run: bash scripts/configure-dev-smtp.sh mailpit
EMAIL_DELIVERY=mailpit
SMTP_DELIVERY=mailpit
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM=noreply@local.test

# Neo4j phishing relationship graph (see docs/neo4j_phishing_graph_guide.md).
NEO4J_ENABLED=true
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=triage-neo4j-dev
GRAPH_INTERNAL_TOKEN=dev-graph-sync-token
BACKEND_INTERNAL_URL=http://backend:3000

# Elasticsearch full-text search (single-node dev; set ELASTICSEARCH_ENABLED=false to disable).
ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_REVIEWS_INDEX=triage-reviews
