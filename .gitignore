# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Python caches and virtual environments
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.venv/
venv/
*.venv

# Build and coverage outputs
build/
dist/
coverage/
htmlcov/
.coverage
frontend/build/

# Local secrets and private env overrides
.env
backend/.env
frontend/.env

# Tracked environment profiles with sample/dev values
!backend/.env.dev
!backend/.env.staging
!backend/.env.prod
!backend/.env.example
!frontend/.env.development

# Logs and local runtime state
*.log
logs/
runtime/
pids/
*.pid
*.pid.lock

# Local database / broker volumes if created outside Docker named volumes
mongo-data/
postgres-data/
kafka-logs/
zookeeper/
redis-data/
docker-data/
volumes/
data/

# Django local outputs
db.sqlite3
*.sqlite3
media/
staticfiles/
static/

# OS and editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
.history/
*.swp
*.swo
*.tmp
*.bak
